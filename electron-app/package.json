{
  "name": "electron-app",
  "private": true,
  "type": "module",
  "main": "./dist-electron/main.js",
  "scripts": {
    "build": "npm run build:renderer && npm run build:electron",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "build:renderer": "react-router build",
    "build:electron": "tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json",
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron:build\" \"npm run dev:preload:build\" \"npm run dev:electron:run\"",
    "dev:renderer": "react-router dev --host localhost --port 5173 --strictPort",
    "dev:electron:build": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:preload:build": "tsc -p tsconfig.preload.json --watch --preserveWatchOutput",
    "dev:electron:run": "wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "start": "electron .",
    "typecheck": "react-router typegen && tsc -p tsconfig.json && tsc -p tsconfig.electron.json --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,mjs}\""
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@react-router/node": "7.13.1",
    "@tanstack/react-query": "^5.96.1",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "isbot": "^5.1.36",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-router": "7.13.1",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@react-router/dev": "7.13.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "wait-on": "^9.0.4"
  }
}
